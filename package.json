{
  "name": "changegittogoogledrive-extension",
  "displayName": "ChangeGitToGoogleDrive",
  "description": "A VS Code extension to sync git commits as bundles with Google Drive",
  "version": "1.3.0",
  "publisher": "VitalyAdadurov",
  "repository": {
    "type": "git",
    "url": "https://github.com/adva-cg/ChangeGitToGoogleDrive.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "changegittogoogledrive-extension.setupGoogleCredentials",
        "title": "1. Настроить учетные данные Google",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.authenticateWithGoogle",
        "title": "2. Аутентификация с Google",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.initialUpload",
        "title": "3. Первоначальная выгрузка истории (Initial Upload)",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.cloneFromGoogleDrive",
        "title": "4. Клонировать проект из Google Drive",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.sync",
        "title": "Синхронизировать историю (Sync)",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.installGitHooks",
        "title": "Установить Git Hooks для авто-синхронизации",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.manageSyncHash",
        "title": "Управление хешем последней синхронизации",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.uploadUntrackedFiles",
        "title": "Неотслеживаемые файлы: Выгрузить на Google Drive (Upload)",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.syncUntrackedFiles",
        "title": "Неотслеживаемые файлы: Синхронизировать с Google Drive (Sync)",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.deleteUntrackedFile",
        "title": "Неотслеживаемые файлы: Удалить файл (в корзину)",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.clearTombstones",
        "title": "Неотслеживаемые файлы: Очистить корзину",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.syncAIHistory",
        "title": "Синхронизировать историю AI",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.configureAIHistorySync",
        "title": "Настроить синхронизацию истории AI для этого проекта",
        "category": "Git-To-Google-Drive"
      },
      {
        "command": "changegittogoogledrive-extension.toggleClipboardSync",
        "title": "Cloud Clipboard: Вкл/Выкл синхронизацию",
        "category": "Git-To-Google-Drive"
      }
    ],
    "configuration": {
      "title": "ChangeGitToGoogleDrive Untracked Files",
      "properties": {
        "changegittogoogledrive-extension.untrackedFiles.include": {
          "type": "array",
          "default": [],
          "description": "Массив glob-шаблонов для файлов, которые должны синхронизироваться как 'неотслеживаемые'."
        },
        "changegittogoogledrive-extension.untrackedFiles.autoUpload": {
          "type": "boolean",
          "default": false,
          "description": "Автоматически выгружать неотслеживаемые файлы при их изменении."
        },
        "changegittogoogledrive-extension.untrackedFiles.syncOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Автоматически синхронизировать неотслеживаемые файлы при запуске VS Code."
        },
        "changegittogoogledrive-extension.untrackedFiles.exclude": {
          "type": "array",
          "default": [],
          "description": "Массив glob-шаблонов для исключения файлов из синхронизации. Имеет приоритет над 'include'."
        },
        "changegittogoogledrive-extension.aiHistory.syncMode": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "always",
            "never"
          ],
          "description": "Как синхронизировать историю бесед AI (Antigravity). 'ask' - спрашивать для каждого проекта."
        },
        "changegittogoogledrive-extension.aiHistory.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Автоматически синхронизировать историю AI при запуске VS Code."
        },
        "changegittogoogledrive-extension.clipboard.syncEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Включить общую облачную корзину (Cloud Clipboard) через Google Drive."
        },
        "changegittogoogledrive-extension.clipboard.syncInterval": {
          "type": "integer",
          "default": 5000,
          "description": "Интервал проверки буфера обмена в миллисекундах (минимум 1000)."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "eslint": "^8.56.0"
  },
  "dependencies": {
    "googleapis": "^153.0.0",
    "minimatch": "^10.0.3"
  }
}